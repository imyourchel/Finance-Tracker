{
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "version": 2,
    "builds": [
        {
            "src": "server.js",
            "use": "@vercel/node"
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "server.js"
        }
    ],
    "crons": [
        {
            "path": "/api/cron/recurring",
            "schedule": "5 17 * * *"
        },
        {
            "path": "/api/cron/budget-alert",
            "schedule": "0 2 * * *"
        },
        {
            "path": "/api/cron/goal-alert",
            "schedule": "5 2 * * *"
        },
        {
            "path": "/api/cron/rollover",
            "schedule": "10 17 1 * *"
        },
        {
            "path": "/api/cron/daily-reminder",
            "schedule": "0 13 * * *"
        }
    ]
}